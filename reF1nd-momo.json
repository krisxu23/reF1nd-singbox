{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "http_clients": [
    {
      "tag": "Direct"
    }
  ],
  "default_http_client": "Direct",
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/etc/momo/run/cache.db",
      "store_fakeip": true,
      "store_dns": true
    },
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "secret": "",
      "default_mode": "rule",
      "external_ui": "/etc/momo/run/ui",
      "external_ui_download_url": "https://ghfast.top/github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "external_ui_http_client": "Direct"
    }
  },
  "providers": [
    {
      "type": "remote",
      "tag": "订阅1",
      "health_check": {
        "enabled": false,
        "url": "https://www.google.com/generate_204",
        "interval": "10m",
        "timeout": "3s"
      },
      "url": "订阅",
      "exclude": "官网|剩余|流量|套餐|免费|订阅|全球直连|到期时间|GB|Expire Date|Traffic|ExpireDate",
      "update_interval": "12h"
    },
    {
      "type": "remote",
      "tag": "订阅2",
      "health_check": {
        "enabled": false,
        "url": "https://www.google.com/generate_204",
        "interval": "10m",
        "timeout": "3s"
      },
      "url": "订阅",
      "exclude": "官网|剩余|流量|套餐|免费|订阅|全球直连|到期时间|GB|Expire Date|Traffic|ExpireDate",
      "update_interval": "1h"
    }
  ],
  "dns": {
    "servers": [
      {
        "tag": "hosts_fix",
        "type": "hosts",
        "predefined": {
          "dns.alidns.com": ["223.5.5.5", "223.6.6.6"],
          "doh.pub": ["1.12.12.21", "120.53.53.53"],
          "dns.google": ["8.8.8.8", "8.8.4.4"],
          "cloudflare-dns.com": ["104.16.248.249", "104.16.249.249"]
        }
      },
      {
        "tag": "ali_dns",
        "type": "https",
        "server": "dns.alidns.com",
        "domain_resolver": "hosts_fix"
      },
      {
        "tag": "ggdns",
        "type": "https",
        "server": "dns.google",
        "domain_resolver": "hosts_fix",
        "detour": "🚀 默认代理"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          ".local", ".lan", "miwifi.com", "tplogin.cn",
          "router.asus.com", "tendawifi.com", "tplinkwifi.net",
          "app-measurement.com", "hm.baidu.com",
          "firebaselogging.googleapis.com", "firebaselogging-pa.googleapis.com",
          "beacons.gvt2.com", "beacons2.gvt2.com", "beacons3.gvt2.com",
          "tracking.miui.com", "market.xiaomi.com", "lancache.steamcontent.com"
        ],
        "server": "ali_dns"
      },
      { "clash_mode": ["Direct", "direct"], "server": "ali_dns" },
      { "clash_mode": ["Global", "global"], "server": "fakeip" },
      { "query_type": ["SVCB", "HTTPS", "PTR"], "action": "reject" },
      { "rule_set": ["ads_domain"], "action": "reject" },
      {
        "rule_set": ["geosite-fakeipfilter", "geosite-cn"],
        "server": "ali_dns"
      },
      {
        "rule_set": ["geosite-ai", "geosite-telegram", "geosite-!cn"],
        "query_type": ["A", "AAAA"],
        "server": "fakeip",
        "rewrite_ttl": 300,
        "client_subnet": "119.134.100.0/24"
      }
    ],
    "final": "ggdns",
    "strategy": "prefer_ipv4",
    "reverse_mapping": true,
    "cache_capacity": 16000
  },
  "inbounds": [
    {
      "tag": "dns-in",
      "type": "direct",
      "listen": "::",
      "listen_port": 1053
    },
    {
      "tag": "tproxy-in",
      "type": "tproxy",
      "listen": "::",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    { "tag": "🎯 全球直连", "type": "direct" },
    { "tag": "🚀 默认代理", "type": "selector", "outbounds": ["🇭🇰 香港自动", "🇯🇵 日本自动", "🇸🇬 狮城自动", "🇺🇲 美国自动", "🇭🇰 香港手动", "🇯🇵 日本手动", "🇸🇬 狮城手动", "🇺🇲 美国手动", "🐸 手动选择", "♻️ 自动选择", "落地选择", "落地自动"] },
    { "tag": "🧠 AI", "type": "selector", "outbounds": ["🚀 默认代理", "🇭🇰 香港自动", "🇯🇵 日本自动", "🇸🇬 狮城自动", "🇺🇲 美国自动", "🇭🇰 香港手动", "🇯🇵 日本手动", "🇸🇬 狮城手动", "🇺🇲 美国手动", "🐸 手动选择", "♻️ 自动选择"] },
    { "tag": "📲 Telegram", "type": "selector", "outbounds": ["🚀 默认代理", "🇭🇰 香港自动", "🇯🇵 日本自动", "🇸🇬 狮城自动", "🇺🇲 美国自动", "🇭🇰 香港手动", "🇯🇵 日本手动", "🇸🇬 狮城手动", "🇺🇲 美国手动", "🐸 手动选择", "♻️ 自动选择"] },
    { "tag": "🐠 漏网之鱼", "type": "selector", "outbounds": ["🚀 默认代理", "🎯 全球直连"] },
    { "tag": "GLOBAL", "type": "selector", "outbounds": ["🚀 默认代理", "🧠 AI", "📲 Telegram", "🐠 漏网之鱼", "🇭🇰 香港手动", "🇯🇵 日本手动", "🇸🇬 狮城手动", "🇺🇲 美国手动", "🐸 手动选择", "♻️ 自动选择", "🍃 前置选择", "🎯 全球直连"] },

    { "tag": "🇭🇰 香港手动", "type": "selector", "providers": ["订阅1"], "include": "港|HK|(?i)Hong", "exclude": "日" },
    { "tag": "🇯🇵 日本手动", "type": "selector", "providers": ["订阅1"], "include": "🇯🇵|JP|jp|日本|日|Japan", "exclude": "HK" },
    { "tag": "🇸🇬 狮城手动", "type": "selector", "providers": ["订阅1"], "include": "新加坡|坡|狮城|SG|Singapore", "exclude": "日" },
    { "tag": "🇺🇲 美国手动", "type": "selector", "providers": ["订阅1"], "include": "🇺🇸|US|us|美国|美|United States", "exclude": "日" },

    { "tag": "🇭🇰 香港自动", "type": "urltest", "providers": ["订阅1"], "url": "https://www.google.com/generate_204", "interval": "3m", "tolerance": 150, "fallback": { "enabled": true, "max_delay": "200ms" }, "include": "港|HK|(?i)Hong", "exclude": "日" },
    { "tag": "🇯🇵 日本自动", "type": "urltest", "providers": ["订阅1"], "url": "https://www.google.com/generate_204", "interval": "3m", "tolerance": 150, "fallback": { "enabled": true, "max_delay": "200ms" }, "include": "🇯🇵|JP|jp|日本|日|Japan", "exclude": "HK" },
    { "tag": "🇸🇬 狮城自动", "type": "urltest", "providers": ["订阅1"], "url": "https://www.google.com/generate_204", "interval": "3m", "tolerance": 150, "fallback": { "enabled": true, "max_delay": "200ms" }, "include": "新加坡|坡|狮城|SG|Singapore", "exclude": "日" },
    { "tag": "🇺🇲 美国自动", "type": "urltest", "providers": ["订阅1"], "url": "https://www.google.com/generate_204", "interval": "3m", "tolerance": 150, "fallback": { "enabled": true, "max_delay": "200ms" }, "include": "🇺🇸|US|us|美国|美|United States", "exclude": "日" },

    { "tag": "🐸 手动选择", "type": "selector", "providers": ["订阅1"], "exclude": "网站|流量|地址|剩余|过期|免费|时间|有效|Traffic|ExpireDate|GB|Expire Date" },
    { "tag": "♻️ 自动选择", "type": "urltest", "providers": ["订阅1", "订阅2"], "url": "https://www.google.com/generate_204", "interval": "3m", "tolerance": 150, "fallback": { "enabled": true, "max_delay": "200ms" }, "exclude": "网站|流量|地址|剩余|过期|免费|时间|有效|Traffic|ExpireDate|GB|Expire Date" },
    { "tag": "🍃 前置选择", "type": "selector", "outbounds": ["♻️ 自动选择", "🐸 手动选择"] }
  ],
  "route": {
    "default_domain_resolver": {"server": "ali_dns"},
    "rules": [
      { "action": "sniff", "sniffer": ["http", "tls", "quic", "dns"] },
      { "inbound": "dns-in", "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "🎯 全球直连" },
      { "clash_mode": ["Direct", "direct"], "outbound": "🎯 全球直连" },
      { "clash_mode": ["Global", "global"], "outbound": "GLOBAL" },
      { "rule_set": ["ads_domain"], "action": "reject" },
      { "rule_set": "geosite-ai", "outbound": "🧠 AI" },
      { "rule_set": ["geosite-telegram", "geoip-telegram"], "outbound": "📲 Telegram" },
      { "rule_set": ["geosite-cn", "geoip-cn"], "outbound": "🎯 全球直连" },
      { "action": "resolve" },
      { "ip_cidr": ["198.18.0.0/15", "fc00::/18"], "outbound": "🚀 默认代理" },
      { "rule_set": "geosite-!cn", "outbound": "🚀 默认代理" }
    ],
    "rule_set": [
      { "tag": "ads_domain", "type": "remote", "format": "source", "url": "https://jsd.onmicrosoft.cn/gh/TG-Twilight/AWAvenue-Ads-Rule@main/Filters/AWAvenue-Ads-Rule-Singbox.json" },
      { "tag": "geosite-fakeipfilter", "type": "remote", "format": "source", "url": "https://gh-proxy.com/https://raw.githubusercontent.com/qichiyuhub/rule/refs/heads/main/rules/fakeipfilter.json" },
      { "tag": "geosite-ai", "type": "remote", "format": "binary", "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/category-ai-!cn.srs", "update_interval": "24h" },
      { "tag": "geosite-telegram", "type": "remote", "format": "binary", "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/telegram.srs", "update_interval": "24h" },
      { "tag": "geosite-!cn", "type": "remote", "format": "binary", "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/geolocation-!cn.srs", "update_interval": "24h" },
      { "tag": "geosite-cn", "type": "remote", "format": "binary", "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/cn.srs", "update_interval": "24h" },
      { "tag": "geoip-telegram", "type": "remote", "format": "binary", "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/telegram.srs", "update_interval": "24h" },
      { "tag": "geoip-cn", "type": "remote", "format": "binary", "url": "https://gh-proxy.com/https://github.com/qljsyph/ruleset-icon/raw/refs/heads/main/sing-box/geoip/China-ASN-combined-ip.srs", "update_interval": "24h" }
    ],
    "final": "🐠 漏网之鱼",
    "auto_detect_interface": true
  }
}
